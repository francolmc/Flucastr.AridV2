# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# LLM Mode
# Options: "hybrid" (use different providers for conversation/reasoning) or "single" (use same provider for everything)
LLM_MODE=hybrid

# LLM Providers (for hybrid mode)
LLM_PROVIDER_CONVERSATION=gemini
LLM_PROVIDER_REASONING=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Ollama (Local LLM - Optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Storage
STORE_PATH=./data/store.json          # JSON con conversaciones, perfiles, tokens
WORKSPACE_PATH=./workspace            # Directorio para PROFILE.md y personalizaciones

# Whisper Speech-to-Text
WHISPER_URL=http://localhost:9000     # URL del servicio Whisper ASR
WHISPER_MODEL=base                    # Modelo Whisper (tiny, base, small, medium, large)
WHISPER_LANGUAGE=es                   # Idioma para transcripción

# Tools (Fase 7 - Herramientas)
TOOLS_WORKSPACE_PATH=./               # Path del workspace para operaciones de archivos (por defecto: directorio actual)
TAVILY_API_KEY=your_tavily_api_key    # API key de Tavily para búsquedas web (opcional)
